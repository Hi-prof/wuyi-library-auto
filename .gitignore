# Android 源码目录不要被上面的 runtime/ 规则误伤
!library-android/core/runtime/
!library-android/core/runtime/**
!library-android/app/src/main/java/com/wuyi/libraryauto/runtime/
!library-android/app/src/main/java/com/wuyi/libraryauto/runtime/**
library-android/core/runtime/build/
library-android/.gradle/
library-android/.gradle*/
library-android/local.properties
library-android/keystore.properties
library-android/keystore/
library-android/*.jks
library-android/*.keystore
library-android/**/hs_err_pid*.log
library-android/**/replay_pid*.log
