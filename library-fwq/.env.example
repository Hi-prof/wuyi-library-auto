PREVENT_AUTO_HOST=127.0.0.1
PREVENT_AUTO_PORT=5000
PREVENT_AUTO_MONITOR_INTERVAL_SECONDS=60
PREVENT_AUTO_REBOOK_POLL_INTERVAL_SECONDS=15
PREVENT_AUTO_LOG_RETENTION_DAYS=30
PREVENT_AUTO_DAILY_STATUS_REFRESH_TIME=08:10
PREVENT_AUTO_AUTH_USERNAME=xuhuangbin
PREVENT_AUTO_AUTH_PASSWORD=xuhuangbin
PREVENT_AUTO_SESSION_SECRET=WuyiAuto!2026#SessionKey7RbTn4YpZs8

# account-pool-tri-sync 用于 Windows / 移动端拉取账号密码的 AES-GCM 密钥；
# 留空时服务端会自动生成并写入 runtime/account_pool_secret.key 持久化复用。
# 需要在多机间共享同一份号池数据时再手动设置 base64 编码后 32 字节的随机密钥。
ACCOUNT_POOL_SECRET_KEY=
ACCOUNT_POOL_TOKEN_PEPPER=prevent_auto_token_pepper_default
ACCOUNT_POOL_REAPER_INTERVAL_SECONDS=300
ACCOUNT_POOL_DETAIL_RATE_LIMIT_PER_MINUTE=6
ACCOUNT_POOL_AUDIT_RETENTION_DAYS=90
ACCOUNT_POOL_HTTPS_REQUIRED=true
